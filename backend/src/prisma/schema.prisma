generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  PARENT
  MODERATOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum AdmissionStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  SELECTED
  REJECTED
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  GRADUATED
  TRANSFERRED
  EXPELLED
}

enum EmploymentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  TERMINATED
  ON_LEAVE
}

enum NotificationType {
  INFO
  WARNING
  ALERT
  ANNOUNCEMENT
  REMINDER
  URGENT
}

enum NotificationChannel {
  IN_APP
  SSE
  EMAIL
  SMS
}

enum AuditAction {
  CREATE
  READ
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PASSWORD_CHANGE
  PASSWORD_RESET
  PERMISSION_CHANGE
  ROLE_CHANGE
  STATUS_CHANGE
  EXPORT
  IMPORT
  APPROVE
  REJECT
  ASSIGN
  UNASSIGN
  GENERATE_REG_NO
  SSE_CONNECT
  SSE_DISCONNECT
  DOCUMENT_UPLOAD
  DOCUMENT_DELETE
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  CRITICAL
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
  HOLIDAY
}

enum ExamType {
  UNIT_TEST
  MID_TERM
  FINAL
  PRACTICAL
  ASSIGNMENT
  PROJECT
  QUIZ
}

enum FeeStatus {
  PENDING
  PAID
  OVERDUE
  WAIVED
  PARTIAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ParentType {
  FATHER
  MOTHER
  GUARDIAN
}

enum DocumentType {
  ADMISSION_FORM
  BIRTH_CERTIFICATE
  TRANSFER_CERTIFICATE
  MARKSHEET
  ID_PROOF
  ADDRESS_PROOF
  PHOTO
  RESUME
  QUALIFICATION_CERTIFICATE
  MEDICAL_CERTIFICATE
  FEE_RECEIPT
  LEAVE_DOCUMENT
  OTHER
}

enum DocumentOwnerType {
  STUDENT
  TEACHER
  ADMIN
  PARENT
  ADMISSION_APPLICATION
  TEACHER_APPLICATION
  LEAVE_REQUEST
  FEE_PAYMENT
  SCHOOL_APPLICATION
}

enum Module {
  // ─── School & Structure ───────────────────────────────
  SCHOOL
  ACADEMIC_YEAR
  CLASS
  SUBJECT

  // ─── User & Profile Management ────────────────────────
  ADMIN
  TEACHER
  STUDENT
  PARENT

  // ─── Applications & Onboarding ────────────────────────
  SCHOOL_APPLICATION
  ADMISSION_APPLICATION
  TEACHER_APPLICATION

  // ─── Assignments ──────────────────────────────────────
  TEACHER_SUBJECT
  CLASS_TEACHER
  ENROLLMENT

  // ─── Scheduling ───────────────────────────────────────
  TIMETABLE
  HOLIDAY

  // ─── Attendance ───────────────────────────────────────
  STUDENT_ATTENDANCE
  TEACHER_ATTENDANCE

  // ─── Exams & Marks ────────────────────────────────────
  EXAM_SCHEDULE
  MARK

  // ─── Finance ──────────────────────────────────────────
  FEE_STRUCTURE
  FEE_PAYMENT

  // ─── Leave ────────────────────────────────────────────
  LEAVE_REQUEST

  // ─── Communication ────────────────────────────────────
  ANNOUNCEMENT
  NOTIFICATION

  // ─── Documents ────────────────────────────────────────
  DOCUMENT

  // ─── System ───────────────────────────────────────────
  AUDIT_LOG
  SYSTEM_LOG
  IP_BLACKLIST
  RATE_LIMIT
}

model School {
  id                    String                 @id @default(cuid())
  name                  String
  code                  String                 @unique
  address               String
  city                  String
  state                 String
  country               String
  pincode               String
  phone                 String
  email                 String                 @unique
  website               String?
  logoUrl               String?
  establishedYear       Int
  affiliationNumber     String?
  boardType             String
  isActive              Boolean                @default(true)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  academicYears         AcademicYear[]
  classes               Class[]
  subjects              Subject[]
  users                 User[]
  admissionApplications AdmissionApplication[]
  teacherApplications   TeacherApplication[]
  announcements         Announcement[]
  feeStructures         FeeStructure[]
  holidays              Holiday[]
  systemLogs            SystemLog[]
  auditLogs             AuditLog[]
  documents             Document[]

  @@index([code])
  @@index([email])
  @@index([isActive])
}

enum SchoolApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  MORE_INFO_REQUIRED
}

model SchoolApplication {
  id                String                     @id @default(cuid())
  schoolName        String
  address           String
  city              String
  state             String
  country           String
  pincode           String
  phone             String
  email             String                     @unique
  website           String?
  establishedYear   Int
  affiliationNumber String?
  boardType         String
  adminFirstName    String
  adminLastName     String
  adminEmail        String                     @unique
  adminPhone        String
  adminGender       Gender
  status            SchoolApplicationStatus    @default(PENDING)
  appliedAt         DateTime                   @default(now())
  reviewedAt        DateTime?
  reviewedBy        String?
  rejectionReason   String?
  notes             String?
  moreInfoFields    String[]                   @default([])
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt
  documents         Document[]                 @relation("SchoolApplicationDocuments")
  histories         SchoolApplicationHistory[]

  @@index([status])
  @@index([email])
  @@index([adminEmail])
}

model AcademicYear {
  id            String         @id @default(cuid())
  schoolId      String
  name          String
  startDate     DateTime
  endDate       DateTime
  isCurrent     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  school        School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classes       Class[]
  enrollments   Enrollment[]
  examSchedules ExamSchedule[]
  feeStructures FeeStructure[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([isCurrent])
  @@index([schoolId, isCurrent])
}

model Class {
  id             String         @id @default(cuid())
  schoolId       String
  academicYearId String
  name           String
  section        String
  capacity       Int            @default(40)
  roomNumber     String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  school         School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  academicYear   AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  enrollments    Enrollment[]
  timetables     Timetable[]
  examSchedules  ExamSchedule[]
  classTeachers  ClassTeacher[]
  feeStructures  FeeStructure[]
  leaveRequest   LeaveRequest[]

  @@unique([schoolId, academicYearId, name, section])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([schoolId, academicYearId])
}

model Subject {
  id              String           @id @default(cuid())
  schoolId        String
  name            String
  code            String
  description     String?
  isElective      Boolean          @default(false)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  teacherSubjects TeacherSubject[]
  timetables      Timetable[]
  examSchedules   ExamSchedule[]
  marks           Mark[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@index([isActive])
}

model RegistrationCounter {
  id        String   @id @default(cuid())
  schoolId  String
  role      Role
  lastCount Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([schoolId, role])
  @@index([schoolId, role])
}

model User {
  id                String                  @id @default(cuid())
  schoolId          String?
  regNumber         String                  @unique
  role              Role
  email             String?                 @unique
  phone             String?
  passwordHash      String
  isActive          Boolean                 @default(true)
  isVerified        Boolean                 @default(false)
  lastLoginAt       DateTime?
  lastLoginIp       String?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  school            School?                 @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  superAdmin        SuperAdmin?
  admin             Admin?
  teacher           Teacher?
  student           Student?
  parent            Parent?
  sessions          Session[]
  notifications     NotificationRecipient[]
  sseConnections    SSEConnection[]
  auditLogs         AuditLog[]              @relation("AuditPerformedBy")
  targetAuditLogs   AuditLog[]              @relation("AuditTargetUser")
  systemLogs        SystemLog[]
  passwordResets    PasswordReset[]
  sentNotifications Notification[]          @relation("NotificationSender")
  userPermission    UserPermission[]

  @@index([schoolId])
  @@index([regNumber])
  @@index([role])
  @@index([email])
  @@index([isActive])
  @@index([schoolId, role])
  @@index([schoolId, isActive])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  ipAddress String
  userAgent String?
  country   String?
  region    String?
  city      String?
  latitude  Float?
  longitude Float?
  isp       String?
  isActive  Boolean  @default(true)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([isActive])
  @@index([expiresAt])
  @@index([userId, isActive])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  ipAddress String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([isUsed])
}

model SuperAdmin {
  id          String    @id @default(cuid())
  userId      String    @unique
  firstName   String
  lastName    String
  gender      Gender
  dateOfBirth DateTime?
  photoUrl    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

